#!/bin/bash

CONFIG_DIR="/etc/alienware-fan"
MODE_FILE="$CONFIG_DIR/ac_mode"
PROFILE_FILE="/sys/firmware/acpi/platform_profile"
INTERVAL=5
EMERGENCY_THRESHOLD=90
EMERGENCY_DURATION=45
RECOVERY_THRESHOLD=82

declare -A AC_PROFILES=(
    [low]="quiet"
    [normal]="balanced-performance"
    [gaming]="performance"
)
declare -A AC_EPP=(
    [low]="power"
    [normal]="balance_power"
    [gaming]="performance"
)
BATTERY_LOCKED_PROFILE="quiet"
BATTERY_LOCKED_EPP="power"

mkdir -p "$CONFIG_DIR"
[ -f "$MODE_FILE" ] || echo "normal" > "$MODE_FILE"

find_hwmon() {
    local name="$1"
    for dir in /sys/class/hwmon/hwmon*/; do
        [ "$(cat "${dir}name" 2>/dev/null)" = "$name" ] && echo "$dir" && return
    done
}

get_cpu_temp() {
    local dir
    dir=$(find_hwmon coretemp) || return 1
    local max=0
    for f in "${dir}"temp*_input; do
        local t
        t=$(cat "$f" 2>/dev/null) || continue
        t=$((t / 1000))
        [ "$t" -gt "$max" ] && max=$t
    done
    echo "$max"
}

ac_online() {
    for f in /sys/class/power_supply/*/type; do
        [ "$(cat "$f" 2>/dev/null)" = "Mains" ] || continue
        online="${f%type}online"
        [ "$(cat "$online" 2>/dev/null)" = "1" ] && return 0
    done
    return 1
}

set_governor() {
    local gov="$1"
    local current_gov
    current_gov=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null)
    [ "$current_gov" = "$gov" ] && return
    echo "$gov" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null 2>&1
    logger -t alienware-fan "governor → $gov"
}

set_epp() {
    local epp="$1"
    local current
    current=$(cat /sys/devices/system/cpu/cpufreq/policy0/energy_performance_preference 2>/dev/null)
    [ "$current" = "$epp" ] && return
    for f in /sys/devices/system/cpu/cpufreq/policy*/energy_performance_preference; do
        echo "$epp" > "$f" 2>/dev/null
    done
    logger -t alienware-fan "EPP → $epp"
}

set_profile() {
    local profile="$1"
    local epp="$2"
    local current
    current=$(cat "$PROFILE_FILE" 2>/dev/null)
    if [ "$current" != "$profile" ]; then
        echo "$profile" > "$PROFILE_FILE"
        logger -t alienware-fan "profile → $profile"
    fi
    set_epp "$epp"
    if [ "$profile" = "performance" ]; then
        set_governor "performance"
    else
        set_governor "powersave"
    fi
}

emergency=false
high_since=0

logger -t alienware-fan "started"

notify_user() {
    local urgency="$1" summary="$2" body="$3"
    local uid display dbus
    uid=$(id -u isma 2>/dev/null) || return
    display=$(grep -z DISPLAY /proc/$(pgrep -u isma hyprland | head -1)/environ 2>/dev/null | tr -d '\0' | cut -d= -f2) || display=":0"
    dbus=$(grep -z DBUS_SESSION_BUS_ADDRESS /proc/$(pgrep -u isma hyprland | head -1)/environ 2>/dev/null | tr -d '\0' | cut -d= -f2-) || return
    sudo -u isma DISPLAY="$display" DBUS_SESSION_BUS_ADDRESS="$dbus" \
        notify-send -u "$urgency" -t 4000 "$summary" "$body" 2>/dev/null || true
}

while true; do
    temp=$(get_cpu_temp)
    now=$(date +%s)

    if [ "$temp" -ge "$EMERGENCY_THRESHOLD" ]; then
        [ "$high_since" -eq 0 ] && high_since=$now
        elapsed=$((now - high_since))
        if [ "$elapsed" -ge "$EMERGENCY_DURATION" ] && [ "$emergency" = false ]; then
            logger -t alienware-fan "EMERGENCY: ${temp}°C for ${elapsed}s — forcing performance"
            notify_user critical "CPU thermal limit" "${temp}°C sustained ${elapsed}s — enforcing performance profile"
            emergency=true
        fi
    else
        high_since=0
        if [ "$emergency" = true ] && [ "$temp" -le "$RECOVERY_THRESHOLD" ]; then
            logger -t alienware-fan "recovery: ${temp}°C — back to normal mode"
            notify_user normal "CPU temperature stable" "Back to ${temp}°C — normal mode restored"
            emergency=false
        fi
    fi

    if [ "$emergency" = true ]; then
        set_profile "performance" "performance"
    elif ac_online; then
        mode=$(cat "$MODE_FILE" 2>/dev/null || echo "normal")
        set_profile "${AC_PROFILES[$mode]:-balanced-performance}" "${AC_EPP[$mode]:-balance_power}"
    else
        if pidof hyprlock > /dev/null 2>&1; then
            set_profile "$BATTERY_LOCKED_PROFILE" "$BATTERY_LOCKED_EPP"
        else
            mode=$(cat "$MODE_FILE" 2>/dev/null || echo "normal")
            if [ "$mode" = "gaming" ]; then
                set_profile "${AC_PROFILES[normal]}" "${AC_EPP[normal]}"
            else
                set_profile "${AC_PROFILES[$mode]}" "${AC_EPP[$mode]}"
            fi
        fi
    fi

    sleep "$INTERVAL"
done
